}

void processarPrioridades(const char *expressao){
    unsigned int nivel_prioridade = 0; // Variável para controlar o nível de prioridade
    int i = 0; // Índice para percorrer a expressão
    while (expressao[i] != '\0') { // Loop até o final da expressão
        char atual = expressao[i]; // Armazena o caractere atual da expressão
        if (atual == '('){
            nivel_prioridade += 10; 
        } else if (atual == ')'){
            nivel_prioridade -= 10; 
        } else if (atual == '[') {
            nivel_prioridade += 20; 
        } else if (atual == ']') {
            nivel_prioridade -= 20; 
        } else if (atual == '{') {
            nivel_prioridade += 30; 
        } else if (atual == '}') {
            nivel_prioridade -= 30; 
        } 
        else if (atual == '+' || atual == '-') {
            unsigned int prioridade_final = nivel_prioridade + 0; 
        }
        else if (atual == '*' || atual == '/' || atual == '%') {
            unsigned int prioridade_final = nivel_prioridade + 1;
        }
        else if (atual == '^') {
            unsigned int prioridade_final = nivel_prioridade + 2;
        }
        else if (atual == '!') {
            unsigned int prioridade_final = nivel_prioridade + 3;
        }
        else if (atual == '|') {
            static int modulo_aberto = 0; 
            
            if (modulo_aberto == 0) {
                nivel_prioridade += 2; 
                modulo_aberto = 1;
            } else {
                nivel_prioridade -= 2; 
                modulo_aberto = 0;
            }
        }
        i++; 
    }
}

